NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/devconnect?retryWrites=true&w=majority

# JWT Secrets (use long random strings)
JWT_ACCESS_SECRET=your_super_secret_access_key_here_make_it_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_make_it_long
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL
CLIENT_URL=http://localhost:5173

# Admin seed
ADMIN_EMAIL=admin@devconnect.com
ADMIN_PASSWORD=Admin123!
